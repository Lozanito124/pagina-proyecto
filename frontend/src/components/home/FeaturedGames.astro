---
const { games = [] } = Astro.props;

function getName(item) {
  return item?.title ?? item?.name ?? "Sin nombre";
}

function getSlug(item) {
  return item?.slug ?? item?.id;
}
---

<section class="mx-auto max-w-6xl px-4 pb-16">
  <div class="mb-5 flex items-end justify-between">
    <div>
      <h2 class="text-xl font-semibold tracking-tight">Juegos destacados</h2>
      <p class="mt-1 text-sm text-neutral-400">
        Una selección inicial del catálogo.
      </p>
    </div>
    <a class="text-sm text-neutral-300 hover:text-white" href="/games">Ver catálogo →</a>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {games.map((g) => (
      <a
        href={`/games/${getSlug(g)}`}
        class="group rounded-2xl border border-white/10 bg-white/5 p-5 hover:border-white/20"
      >
        <p class="text-sm font-semibold text-neutral-100">{getName(g)}</p>
        <p class="mt-2 text-xs text-neutral-400">Abrir ficha →</p>
      </a>
    ))}
  </div>
</section>
