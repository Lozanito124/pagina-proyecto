---
import Layout from "../../layouts/Layout.astro";
import { fetchJSON } from "../../lib/api";

export const prerender = true;

export async function getStaticPaths() {
  try {
    const res = await fetchJSON("/api/articles?pagination%5BpageSize%5D=200");
    const articles = res?.data ?? [];
    let pageRes = { data: null };
    try { pageRes = await fetchJSON("/api/article-page"); } catch (e) {}
    return articles.map((a: any) => {
      const d = a?.attributes ?? a;
      return {
        params: { slug: d?.slug ?? String(a.id) },
        props: { articleData: a, pageData: pageRes?.data },
      };
    });
  } catch (e) {
    console.error("getStaticPaths articles error:", e);
    return [];
  }
}

const { articleData, pageData } = Astro.props;

const d = articleData ? (articleData?.attributes ?? articleData) : null;
const p = pageData ?? {};

const ui = {
  backLabel:p.backLabel,
  notFoundTitle:p.notFoundTitle,
  notFoundSub:p.notFoundSub,
  notFoundBtn:p.notFoundBtn,
  readingTimeSuffix: p.readingTimeSuffix ,
};

function calcReadingTime(text: string): number {
  if (!text) return 1;
  const plain = text.replace(/<[^>]*>/g, "").trim();
  const words = plain.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

function extractBlocks(raw: any): { type: string; text: string }[] {
  if (!raw) return [];
  if (typeof raw === "string") {
    return raw.split("\n\n").filter(Boolean).map(t => ({ type: "paragraph", text: t.trim() }));
  }
  if (Array.isArray(raw)) {
    return raw.map((block: any) => {
      const text = Array.isArray(block?.children)
        ? block.children.map((c: any) => c?.text ?? "").join("")
        : String(block ?? "");
      return { type: block?.type ?? "paragraph", text };
    }).filter(b => b.text.trim());
  }
  return [];
}

function extractPlainText(raw: any): string {
  if (!raw) return "";
  if (typeof raw === "string") return raw;
  if (Array.isArray(raw)) {
    return raw.map((b: any) =>
      Array.isArray(b?.children) ? b.children.map((c: any) => c?.text ?? "").join("") : ""
    ).join(" ");
  }
  return "";
}

const title         = d?.title;
const author        = d?.author;
const publishedAt   = d?.publishedAt ;
const coverRaw      = d?.cover?.data?.attributes ;
const coverUrl      = coverRaw?.url
  ? (coverRaw.url.startsWith("http") ? coverRaw.url : (import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.gamevault.es") + coverRaw.url)
  : null;
const contentRaw = d?.content;
const contentBlocks = extractBlocks(contentRaw);
const plainText = extractPlainText(contentRaw);
const readingTime = calcReadingTime(plainText);
const excerpt = d?.excerpt ?? plainText.slice(0, 155);
const pageTitle = d ? `GameVault | ${title}` : "GameVault | Artículo no encontrado";

function formatDate(dateStr: string | null): string | null {
  if (!dateStr) return null;
  const dt = new Date(dateStr);
  if (isNaN(dt.getTime())) return null;
  return dt.toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" });
}
const date = formatDate(publishedAt);

const introBlock = contentBlocks[0];
const bodyBlocks = contentBlocks.slice(1);
---

<Layout title={pageTitle} description={excerpt} image={coverUrl ?? undefined}>
  <div class="min-h-screen bg-zinc-950 text-zinc-100">

    {!d && (
      <div class="max-w-2xl mx-auto px-6 py-32 text-center">
        <h1 class="text-3xl font-bold text-white mb-3">{ui.notFoundTitle}</h1>
        <p class="text-zinc-400 mb-8">{ui.notFoundSub}</p>
        <a href="/articles"
          class="inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-6 py-3 rounded-xl transition-all text-sm">
          {ui.notFoundBtn}
        </a>
      </div>
    )}

    {d && (
      <div>
        <div class="max-w-3xl mx-auto px-6 pt-8">
          <a href="/articles"
            class="inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-violet-400 transition-colors">
            {ui.backLabel}
          </a>
        </div>

        <article class="max-w-3xl mx-auto px-6 py-10">

          <div class="flex flex-wrap items-center gap-3 mb-6">
            {author && (
              <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-zinc-400 bg-zinc-900 border border-zinc-800 px-3 py-1.5 rounded-full">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                {author}
              </span>
            )}
            <span class="inline-flex items-center gap-1.5 text-xs font-medium text-violet-400 bg-violet-950/40 border border-violet-800/40 px-3 py-1.5 rounded-full">
              <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
              {readingTime} {ui.readingTimeSuffix}
            </span>
            {date && (
              <span class="text-xs text-zinc-600 font-medium">{date}</span>
            )}
          </div>

          <h1 class="text-4xl sm:text-5xl font-black tracking-tight text-white mb-6 leading-tight">
            {title}
          </h1>

          {introBlock && (
            <p class="text-lg text-zinc-300 leading-relaxed mb-8 border-l-4 border-violet-600 pl-5 italic">
              {introBlock.text}
            </p>
          )}

          {coverUrl && (
            <div class="rounded-2xl overflow-hidden border border-zinc-800 mb-10">
              <img
                src={coverUrl}
                alt={`Imagen del artículo: ${title}`}
                class="w-full h-72 object-cover"
                loading="lazy"
              />
            </div>
          )}

          <div class="flex items-center gap-3 my-8">
            <div class="h-px flex-1 bg-zinc-800"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-violet-600"></div>
            <div class="w-1 h-1 rounded-full bg-zinc-600"></div>
            <div class="h-px flex-1 bg-zinc-800"></div>
          </div>

          {bodyBlocks.length > 0 && (
            <div class="space-y-5">
              {bodyBlocks.map((block) => {
                if (block.type === "heading") {
                  return (
                    <h2 class="text-2xl font-bold text-white mt-12 mb-3 pb-2 border-b border-zinc-800">
                      {block.text}
                    </h2>
                  );
                }
                if (block.type === "heading-3") {
                  return (
                    <h3 class="text-xl font-semibold text-zinc-200 mt-8 mb-2">
                      {block.text}
                    </h3>
                  );
                }
                if (block.type === "list") {
                  return (
                    <p class="text-zinc-400 leading-relaxed text-base pl-4 border-l-2 border-zinc-700">
                      {block.text}
                    </p>
                  );
                }
                if (block.text.length < 80 && block.text === block.text.toUpperCase() && block.text.length > 5) {
                  return (
                    <h2 class="text-lg font-black tracking-widest text-violet-400 mt-12 mb-3 uppercase">
                      {block.text}
                    </h2>
                  );
                }
                return (
                  <p class="text-zinc-400 leading-relaxed text-base">
                    {block.text}
                  </p>
                );
              })}
            </div>
          )}

          <div class="mt-16 pt-8 border-t border-zinc-800 flex items-center justify-between flex-wrap gap-4">
            <a href="/articles"
              class="inline-flex items-center gap-2 text-sm font-semibold text-violet-400 hover:text-violet-300 transition-colors">

              {ui.backLabel}
            </a>
            <span class="text-xs text-zinc-600">
              {readingTime} {ui.readingTimeSuffix} · GameVault
            </span>
          </div>
        </article>
      </div>
    )}
  </div>
</Layout>