---
import Layout from "../../layouts/Layout.astro";
import { fetchJSON } from "../../lib/api";

export const prerender = true;

export async function getStaticPaths() {
  try {
    const res = await fetchJSON("/api/games?pagination%5BpageSize%5D=200&populate=*");
    const games = res?.data ?? [];
    let pageRes = { data: null };
    try { pageRes = await fetchJSON("/api/game-page"); } catch (e) {}
    return games.map((g: any) => {
      const a = g?.attributes ?? g;
      return {
        params: { slug: a?.slug ?? String(g.id) },
        props: { gameData: g, pageData: pageRes?.data },
      };
    });
  } catch {
    return [];
  }
}

const { gameData, pageData } = Astro.props;

const gameRaw = gameData ? (gameData?.attributes ?? gameData) : null;
const p       = pageData ?? {};

const ui = {
  backLabel: p?.backlabel ?? p?.backLabel,
  releaseDateLabel: p?.releaseDateLabel ?? p?.releasedatelabel,
  notFoundTitle: p?.notFoundTitle  ,
  notFoundBtn: p?.notFoundBtn  ,
  gamePlaceholder: p?.gamePlaceholder  ,
  noImageText: p?.noImageText,
  noDescText: p?.noDescText  ,
};

function extractText(raw: any): string {
  if (!raw) return "";
  if (typeof raw === "string") return raw;
  if (Array.isArray(raw)) {
    return raw.map((b: any) =>
      Array.isArray(b?.children) ? b.children.map((c: any) => c?.text ?? "").join("") : ""
    ).join("\n\n").trim();
  }
  return "";
}

const catAttrs = gameRaw?.category?.data?.attributes ?? gameRaw?.category ?? null;

const game = gameRaw ? {
  title: gameRaw.title ,
  slug: gameRaw.slug ,
  description:  extractText(gameRaw.description),
  release_date: gameRaw.release_date ?? null,
  category: catAttrs?.name  ,
  categorySlug: catAttrs?.slug ,
  accentColor:  catAttrs?.accentColor  ,
  bgColor: catAttrs?.bgColor  ,
  borderColor: catAttrs?.borderColor  ,
  images: (() => {
    const STRAPI = import.meta.env.PUBLIC_API_BASE_URL ?? "https://api.gamevault.es";
    const toUrl = (u: string | null) => u ? (u.startsWith("http") ? u : STRAPI + u) : null;
    const coverRaw = gameRaw?.cover;
    if (Array.isArray(coverRaw)) {
      return coverRaw.map((img: any) => toUrl(img?.url ?? null)).filter(Boolean);
    }
    if (coverRaw?.data) {
      const d = coverRaw.data;
      if (Array.isArray(d)) return d.map((img: any) => toUrl(img?.attributes?.url ?? null)).filter(Boolean);
      return d?.attributes?.url ? [toUrl(d.attributes.url)] : [];
    }
    const scrRaw = gameRaw?.screenshots?.data ?? gameRaw?.screenshots ?? [];
    if (Array.isArray(scrRaw)) return scrRaw.map((s: any) => toUrl(s?.attributes?.url ?? s?.url ?? null)).filter(Boolean);
    return [];
  })(),
} : null;

const allImages = game?.images ?? [];

function formatDate(dateStr: string | null): string | null {
  if (!dateStr) return null;
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return null;
  return d.toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" });
}

const pageTitle = game ? "GameVault | " + game.title : "GameVault | No encontrado";
const descParagraphs = game?.description ? game.description.split("\n\n").filter(Boolean) : [];
---

<Layout title={pageTitle}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Outfit', sans-serif; }
    .thumb-btn {
      cursor: pointer;
      opacity: 0.45;
      border: 2px solid transparent;
      transition: opacity 0.15s, border-color 0.15s;
    }
    .thumb-btn:hover { opacity: 0.75; }
    .thumb-btn.active { opacity: 1; }
    .slide { transition: opacity 0.25s ease; }
  </style>

  <div class="min-h-screen bg-zinc-950 text-zinc-100">

    {!game && (
      <div class="max-w-2xl mx-auto px-6 py-32 text-center">
        <h1 class="text-3xl font-bold text-white mb-8">{ui.notFoundTitle}</h1>
        <a href="/games" class="inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-6 py-3 rounded-xl transition-all text-sm">{ui.notFoundBtn}</a>
      </div>
    )}

    {game && (
      <div>
        <div class="border-b border-zinc-800/60">
          <div class="max-w-6xl mx-auto px-6 py-4">
            <a href="/games" class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-violet-400 transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
              </svg>
              {ui.backLabel}
            </a>
          </div>
        </div>

        <div class="max-w-6xl mx-auto px-6 py-10">

          <div class="mb-8">
            {game.category && (
              <a
                href={"/categories/" + game.categorySlug}
                class="inline-flex items-center text-xs font-semibold px-3 py-1 rounded-full border mb-4 tracking-wide hover:opacity-80 transition-opacity"
                style={"color:" + game.accentColor + "; background:" + game.bgColor + "; border-color:" + game.borderColor}
              >
                {game.category}
              </a>
            )}
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-white mb-3 leading-tight">{game.title}</h1>
            {game.release_date && (
              <p class="text-sm text-zinc-500 flex items-center gap-2">
                <svg class="w-4 h-4 text-zinc-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="4" width="18" height="18" rx="2"/>
                  <line x1="16" y1="2" x2="16" y2="6"/>
                  <line x1="8" y1="2" x2="8" y2="6"/>
                  <line x1="3" y1="10" x2="21" y2="10"/>
                </svg>
                {ui.releaseDateLabel}&nbsp;<strong class="text-zinc-300 font-semibold">{formatDate(game.release_date)}</strong>
              </p>
            )}
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">

            <div>
              <div
                class="relative rounded-2xl overflow-hidden bg-zinc-900 border border-zinc-800 w-full"
                style="aspect-ratio: 16/9;"
              >
                {allImages.length > 0 ? (
                  allImages.map((url, i) => (
                    <img
                      id={"slide-" + i}
                      src={url}
                      alt={game.title}
                      class={"slide absolute inset-0 w-full h-full object-cover " + (i === 0 ? "opacity-100" : "opacity-0")}
                    />
                  ))
                ) : (
                  <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 text-zinc-600">
                    <span class="text-7xl">{ui.gamePlaceholder}</span>
                    <span class="text-sm font-medium">{ui.noImageText}</span>
                  </div>
                )}
              </div>

              {allImages.length > 1 && (
                <div class="flex gap-2 mt-3 overflow-x-auto pb-1">
                  {allImages.map((url, i) => (
                    <button
                      class={"thumb-btn flex-shrink-0 w-20 h-14 rounded-xl overflow-hidden bg-zinc-900 border border-zinc-800 " + (i === 0 ? "active" : "")}
                      data-index={String(i)}
                      style={i === 0 ? ("border-color:" + game.accentColor) : ""}
                      onclick={"selectSlide(" + i + ", '" + game.accentColor + "')"}
                    >
                      <img src={url} alt={"img " + (i + 1)} class="w-full h-full object-cover pointer-events-none"/>
                    </button>
                  ))}
                </div>
              )}
            </div>

            <div class="space-y-4">
              {descParagraphs.length > 0 ? (
                descParagraphs.map((para) => (
                  <p class="text-zinc-300 leading-relaxed text-[15px]">{para}</p>
                ))
              ) : (
                <p class="text-zinc-500 italic text-sm">{ui.noDescText}</p>
              )}
            </div>

          </div>
        </div>
      </div>
    )}
  </div>

  <script>
    function selectSlide(index: number, accent: string) {
      const total = document.querySelectorAll('[id^="slide-"]').length;
      for (let i = 0; i < total; i++) {
        const slide = document.getElementById('slide-' + i) as HTMLElement | null;
        if (slide) slide.style.opacity = i === index ? '1' : '0';
      }
      document.querySelectorAll('.thumb-btn').forEach((btn, i) => {
        const el = btn as HTMLElement;
        el.classList.toggle('active', i === index);
        el.style.borderColor = i === index ? accent : 'transparent';
      });
    }
    (window as any).selectSlide = selectSlide;
  </script>
</Layout>