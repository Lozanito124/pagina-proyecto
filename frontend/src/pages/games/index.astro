---
const API_URL = "http://localhost:1337";

// Helper fetch JSON con error detallado
async function getJson(path: string) {
  const res = await fetch(`${API_URL}${path}`);
  if (!res.ok) {
    const txt = await res.text().catch(() => "");
    throw new Error(`Strapi ${res.status} on ${path} ${txt}`);
  }
  return res.json();
}

let page: any = null;
let games: any[] = [];
let error = "";

try {
  // ✅ Single Type: como lo llamaste "gamePage", el endpoint suele ser /api/game-page
  // Si te diera 404, cambia a /api/gamePage?populate=*
  const pageJson = await getJson("/api/game-page?populate=*");
  page = pageJson.data ?? null;

  // ✅ Juegos
  const gamesJson = await getJson("/api/games?populate=*");
  games = gamesJson.data ?? [];
} catch (e) {
  error = e instanceof Error ? e.message : "Unknown error";
}

// Datos page (Strapi v5 normalmente devuelve campos directos)
const pageFields = page?.attributes ?? page ?? {};
const pageSeo = pageFields?.seo ?? {};
const metaTitle = pageSeo?.metaTitle ?? "Juegos | GameVault";
const metaDescription = pageSeo?.metaDescription ?? "";
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{metaTitle}</title>
    {metaDescription && <meta name="description" content={metaDescription} />}
  </head>

  <body style="font-family: system-ui; margin: 24px;">
    {error ? (
      <p style="color: red;">Error: {error}</p>
    ) : (
      <>
        <header style="margin-bottom: 18px;">
          <h1 style="margin: 0 0 8px;">{pageFields?.h1 ?? "Juegos"}</h1>
          {pageFields?.intro && (
            <p style="margin: 0; opacity: 0.85; max-width: 70ch;">
              {pageFields.intro}
            </p>
          )}
        </header>

        {games.length === 0 ? (
          <p>No hay juegos aún.</p>
        ) : (
          <div
            style="
              display: grid;
              grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
              gap: 16px;
            "
          >
            {games.map((g) => {
              // Strapi v5: campos directos. (Por si acaso, soporta v4 también)
              const attrs = g.attributes ?? g;

              const title = attrs.title;
              const slug = attrs.slug;
              const excerpt = attrs.excerpt;
              const rating = attrs.rating;

              // Cover: v5 => attrs.cover.url | v4 => attrs.cover.data.attributes.url
              const coverUrl =
                attrs.cover?.url
                  ? `${API_URL}${attrs.cover.url}`
                  : attrs.cover?.data?.attributes?.url
                    ? `${API_URL}${attrs.cover.data.attributes.url}`
                    : null;

              return (
                <a
                  href={`/games/${slug}`}
                  style="text-decoration: none; color: inherit;"
                >
                  <article
                    style="
                      border: 1px solid #3333;
                      border-radius: 12px;
                      padding: 12px;
                    "
                  >
                    {coverUrl && (
                      <img
                        src={coverUrl}
                        alt={title}
                        style="
                          width: 100%;
                          height: 280px;
                          object-fit: cover;
                          border-radius: 10px;
                        "
                        loading="lazy"
                      />
                    )}

                    <h2 style="margin: 12px 0 6px;">{title}</h2>

                    {typeof rating === "number" && (
                      <p style="margin: 0 0 6px;">⭐ {rating}</p>
                    )}

                    {excerpt && (
                      <p style="margin: 0; opacity: 0.85;">{excerpt}</p>
                    )}
                  </article>
                </a>
              );
            })}
          </div>
        )}
      </>
    )}
  </body>
</html>
