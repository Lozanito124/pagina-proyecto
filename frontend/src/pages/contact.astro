---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="GameVault | Contacto"
  description="¿Tienes alguna pregunta, sugerencia o quieres colaborar con GameVault? Escríbenos."
>
  <div class="min-h-screen bg-zinc-950 relative overflow-hidden">

    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute top-0 left-1/3 w-96 h-96 bg-violet-600/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-violet-800/8 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-5xl mx-auto px-6 py-16 lg:py-24">

      <div class="mb-14">
        <span class="inline-block text-xs font-bold tracking-widest text-violet-400 uppercase mb-4 border border-violet-800/50 bg-violet-950/40 px-3 py-1.5 rounded-full">
          Contacto
        </span>
        <h1 class="text-5xl sm:text-6xl font-black text-white tracking-tight leading-none mb-4">
          Hablemos
        </h1>
        <p class="text-zinc-400 text-lg max-w-md leading-relaxed">
          ¿Tienes una sugerencia, quieres colaborar o simplemente quieres contarnos algo?
          Estamos aquí para escucharte.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 items-start">

        <div class="lg:col-span-2 space-y-6">
          <div class="bg-zinc-900/60 border border-zinc-800 rounded-2xl p-6">
            <div class="w-10 h-10 bg-violet-600/20 border border-violet-700/40 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
              </svg>
            </div>
            <h3 class="text-sm font-bold text-white mb-1">Email</h3>
            <p class="text-zinc-400 text-sm">soporte@gamevault.es</p>
          </div>

          <div class="bg-zinc-900/60 border border-zinc-800 rounded-2xl p-6">
            <div class="w-10 h-10 bg-violet-600/20 border border-violet-700/40 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <h3 class="text-sm font-bold text-white mb-1">Tiempo de respuesta</h3>
            <p class="text-zinc-400 text-sm">Respondemos en menos de 48 horas.</p>
          </div>

          <div class="bg-zinc-900/60 border border-zinc-800 rounded-2xl p-6">
            <div class="w-10 h-10 bg-violet-600/20 border border-violet-700/40 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-violet-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z"/>
              </svg>
            </div>
            <h3 class="text-sm font-bold text-white mb-1">Colaboraciones</h3>
            <p class="text-zinc-400 text-sm">¿Quieres escribir para GameVault? Cuéntanoslo.</p>
          </div>
        </div>

        <div class="lg:col-span-3">
          <div class="bg-zinc-900/60 border border-zinc-800 rounded-2xl p-8">

            <form id="contact-form" novalidate class="space-y-5">

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">
                    Nombre <span class="text-violet-500">*</span>
                  </label>
                  <input
                    type="text" id="name" name="name" autocomplete="name"
                    placeholder="Tu nombre"
                    class="field w-full bg-zinc-950 border border-zinc-700 rounded-xl px-4 py-3 text-white text-sm placeholder-zinc-600 focus:outline-none focus:border-violet-500 transition-colors"
                  />
                  <p id="name-error" class="field-error hidden text-red-400 text-xs mt-1.5 flex items-center gap-1">
                    <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    Mínimo 2 caracteres
                  </p>
                </div>

                <div>
                  <label for="email" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">
                    Email <span class="text-violet-500">*</span>
                  </label>
                  <input
                    type="email" id="email" name="email" autocomplete="email"
                    placeholder="tu@email.com"
                    class="field w-full bg-zinc-950 border border-zinc-700 rounded-xl px-4 py-3 text-white text-sm placeholder-zinc-600 focus:outline-none focus:border-violet-500 transition-colors"
                  />
                  <p id="email-error" class="field-error hidden text-red-400 text-xs mt-1.5 flex items-center gap-1">
                    <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    Email no válido
                  </p>
                </div>
              </div>

              <div>
                <label for="subject" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">
                  Asunto
                </label>
                <select
                  id="subject" name="subject"
                  class="w-full bg-zinc-950 border border-zinc-700 rounded-xl px-4 py-3 text-zinc-300 text-sm focus:outline-none focus:border-violet-500 transition-colors"
                >
                  <option value="">Selecciona un asunto...</option>
                  <option value="sugerencia">Sugerencia de juego</option>
                  <option value="colaboracion">Quiero colaborar</option>
                  <option value="error">Reportar un error</option>
                  <option value="otro">Otro</option>
                </select>
              </div>

              <div>
                <label for="message" class="block text-xs font-bold text-zinc-400 uppercase tracking-widest mb-2">
                  Mensaje <span class="text-violet-500">*</span>
                </label>
                <textarea
                  id="message" name="message" rows="5"
                  placeholder="¿En qué podemos ayudarte?"
                  class="field w-full bg-zinc-950 border border-zinc-700 rounded-xl px-4 py-3 text-white text-sm placeholder-zinc-600 focus:outline-none focus:border-violet-500 transition-colors resize-none"
                ></textarea>
                <div class="flex justify-between items-center mt-1.5">
                  <p id="message-error" class="field-error hidden text-red-400 text-xs flex items-center gap-1">
                    <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
                    Mínimo 10 caracteres
                  </p>
                  <span id="char-count" class="text-xs text-zinc-600 ml-auto">0 / 500</span>
                </div>
              </div>

              <button
                type="submit" id="submit-btn"
                class="w-full bg-violet-600 hover:bg-violet-500 active:bg-violet-700 text-white font-bold py-3.5 px-6 rounded-xl transition-all text-sm flex items-center justify-center gap-2 group"
              >
                <span id="btn-text">Enviar mensaje</span>
                <svg id="btn-icon" class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
                </svg>
                <svg id="btn-spinner" class="w-4 h-4 animate-spin hidden" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
              </button>
            </form>

            <div id="form-success" class="hidden text-center py-10">
              <div class="w-16 h-16 bg-green-900/30 border border-green-700/50 rounded-full flex items-center justify-center mx-auto mb-5">
                <svg class="w-8 h-8 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <h3 class="text-xl font-bold text-white mb-2">¡Mensaje enviado!</h3>
              <p class="text-zinc-400 text-sm mb-6">Te responderemos en menos de 48 horas.</p>
              <button
                onclick="resetForm()"
                class="text-sm text-violet-400 hover:text-violet-300 transition-colors underline underline-offset-4"
              >
                Enviar otro mensaje
              </button>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  const REGEX = {
    name:    /^.{2,50}$/,
    email:   /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/,
    message: /^[\s\S]{10,500}$/,
  };

  type FieldId = "name" | "email" | "message";

  function getField(id: string) {
    return document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement;
  }

  function showError(id: string, show: boolean) {
    const error = document.getElementById(`${id}-error`);
    const field = getField(id);
    if (!error || !field) return;
    error.classList.toggle("hidden", !show);
    if (show) {
      field.classList.add("border-red-500");
      field.classList.remove("border-zinc-700", "border-green-600");
    } else {
      field.classList.remove("border-red-500");
      field.classList.add("border-green-600");
      field.classList.remove("border-zinc-700");
    }
  }

  function validate(id: FieldId): boolean {
    const field = getField(id);
    if (!field) return false;
    const valid = REGEX[id].test(field.value);
    showError(id, !valid);
    return valid;
  }

  const msgField = document.getElementById("message") as HTMLTextAreaElement;
  const charCount = document.getElementById("char-count");
  msgField?.addEventListener("input", () => {
    const len = msgField.value.length;
    if (charCount) {
      charCount.textContent = `${len} / 500`;
      charCount.classList.toggle("text-red-400", len > 500);
      charCount.classList.toggle("text-zinc-600", len <= 500);
    }
  });

  (["name", "email", "message"] as FieldId[]).forEach(id => {
    getField(id)?.addEventListener("blur",  () => validate(id));
    getField(id)?.addEventListener("input", () => {
      if (!document.getElementById(`${id}-error`)?.classList.contains("hidden")) {
        validate(id);
      }
    });
  });

  document.getElementById("contact-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fields: FieldId[] = ["name", "email", "message"];
    const allValid = fields.map(f => validate(f)).every(Boolean);
    if (!allValid) return;

    const btn     = document.getElementById("submit-btn") as HTMLButtonElement;
    const btnText = document.getElementById("btn-text");
    const btnIcon = document.getElementById("btn-icon");
    const spinner = document.getElementById("btn-spinner");
    btn.disabled = true;
    btnText!.textContent = "Enviando...";
    btnIcon?.classList.add("hidden");
    spinner?.classList.remove("hidden");

    await new Promise(r => setTimeout(r, 1200));

    document.getElementById("contact-form")!.classList.add("hidden");
    document.getElementById("form-success")!.classList.remove("hidden");
  });

  (window as any).resetForm = function() {
    const form    = document.getElementById("contact-form")!;
    const success = document.getElementById("form-success")!;
    form.classList.remove("hidden");
    success.classList.add("hidden");
    (form as HTMLFormElement).reset();
    const btn     = document.getElementById("submit-btn") as HTMLButtonElement;
    const btnText = document.getElementById("btn-text");
    const btnIcon = document.getElementById("btn-icon");
    const spinner = document.getElementById("btn-spinner");
    btn.disabled  = false;
    btnText!.textContent = "Enviar mensaje";
    btnIcon?.classList.remove("hidden");
    spinner?.classList.add("hidden");
    ["name","email","message"].forEach(id => {
      const f = getField(id);
      f?.classList.remove("border-red-500","border-green-600");
      f?.classList.add("border-zinc-700");
    });
    if (charCount) charCount.textContent = "0 / 500";
  };
</script>