---
import Layout from "../../layouts/Layout.astro";
import { fetchJSON } from "../../lib/api";

export const prerender = true;

export async function getStaticPaths() {
  try {
    const res = await fetchJSON("/api/categories?pagination[pageSize]=50");
    const categories = res?.data ?? [];
    let pageRes = { data: null };
    try { pageRes = await fetchJSON("/api/category-page"); } catch (e) {}
    return categories.map((c: any) => {
      const a = c?.attributes ?? c;
      return {
        params: { slug: a?.slug ?? String(c.id) },
        props: { categoryData: c, pageData: pageRes?.data },
      };
    });
  } catch {
    return [];
  }
}

const { categoryData, pageData } = Astro.props;

const catRaw = categoryData ? (categoryData?.attributes ?? categoryData) : null;
const p = pageData ?? {};

const ui = {
  backLabel: p?.backlabel,
  gamesTitle: p?.gamesTitle,
  gamesCountLabel: p?.gamesCountLabel,
  emptyText: p?.emptyText,
  notFoundTitle: p?.notFoundTitle,
  notFoundBtn: p?.notFoundBtn,
};

function extractText(raw: any): string {
  if (!raw) return "";
  if (typeof raw === "string") return raw;
  if (Array.isArray(raw)) {
    return raw.map((b: any) =>
      Array.isArray(b?.children) ? b.children.map((c: any) => c?.text ?? "").join("") : ""
    ).join(" ").trim();
  }
  return "";
}


const cat = catRaw ? {
  name: catRaw.name ,
  slug: catRaw.slug,
  description: extractText(catRaw.description),
  icon: catRaw.icon,
  accentColor: catRaw.accentColor ?? DEFAULT_ACCENT,
  bgColor: catRaw.bgColor,
  borderColor: catRaw.borderColor,
} : null;

let gamesRes = { data: [] };
if (cat) {
  try {
    gamesRes = await fetchJSON(
      "/api/games?filters%5Bcategory%5D%5Bslug%5D%5B%24eq%5D=" + cat.slug +
      "&populate=*&pagination%5BpageSize%5D=100"
    );
  } catch (e) { console.error(e); }
}

const rawGames = gamesRes?.data ?? [];
const games = rawGames.map((g: any) => {
  const a = g;
  const catAttrs = a?.category;
  return {
    title: a?.title,
    slug: a?.slug,
    description: extractText(a?.description),
    release_date: a?.release_date,
    category: catAttrs?.name,
    accentColor: catAttrs?.accentColor,
    bgColor: catAttrs?.bgColor,
    borderColor:  catAttrs?.borderColor,
  };
});

function formatDate(dateStr: string | null): string | null {
  if (!dateStr) return null;
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return null;
  return d.toLocaleDateString("es-ES", { year: "numeric", month: "short", day: "numeric" });
}

const pageTitle  = cat ? "GameVault | " + cat.name : "GameVault | No encontrado";
const gamesCount = games.length + " " + (ui.gamesCountLabel ?? "juegos");
---

<Layout title={pageTitle}>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap');
    body { font-family: 'Outfit', sans-serif; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  </style>

  <div class="min-h-screen bg-zinc-950 text-zinc-100">

    {!cat && (
      <div class="max-w-2xl mx-auto px-6 py-32 text-center">
        <p class="text-6xl mb-6">📂</p>
        <h1 class="text-3xl font-bold text-white mb-8">{ui.notFoundTitle}</h1>
        <a href="/categories" class="inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-6 py-3 rounded-xl transition-all text-sm">{ui.notFoundBtn}</a>
      </div>
    )}

    {cat && (
      <div>
        <div class="border-b" style={"background:" + cat.bgColor + "; border-color:" + cat.borderColor}>
          <div class="max-w-6xl mx-auto px-6 py-16">
            <a href="/categories" class="inline-flex items-center gap-2 text-sm text-zinc-400 hover:text-violet-400 transition-colors mb-6">
              {ui.backLabel}
            </a>
            <div class="flex items-center gap-4 mb-3">
              <span class="text-5xl">{cat.icon}</span>
              <h1 class="text-5xl font-extrabold tracking-tight text-white">{cat.name}</h1>
            </div>
            {cat.description && <p class="text-zinc-400 text-lg max-w-2xl mt-3">{cat.description}</p>}
            <p class="text-sm mt-4 font-semibold" style={"color:" + cat.accentColor}>{gamesCount}</p>
          </div>
        </div>

        <div class="max-w-6xl mx-auto px-6 py-12">
          <h2 class="text-2xl font-bold text-white mb-8">{ui.gamesTitle}</h2>

          {games.length === 0 ? (
            <p class="text-zinc-500 text-center py-24">{ui.emptyText}</p>
          ) : (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {games.map((game) => {
                const date = formatDate(game.release_date);
                return (
                  <a href={"/games/" + game.slug} class="group flex flex-col bg-zinc-900 border border-zinc-800/80 rounded-2xl overflow-hidden hover:-translate-y-1 hover:shadow-2xl transition-all duration-200">
                    <div class="h-0.5 w-full opacity-0 group-hover:opacity-100 transition-opacity duration-200" style={"background:" + game.accentColor}></div>
                    <div class="flex flex-col flex-1 p-5">
                      {game.category && (
                        <span class="self-start text-xs font-semibold px-2.5 py-1 rounded-full border mb-3 tracking-wide" style={"color:" + game.accentColor + "; background:" + game.bgColor + "; border-color:" + game.borderColor}>
                          {game.category}
                        </span>
                      )}
                      <h3 class="text-base font-bold text-zinc-100 group-hover:text-violet-400 transition-colors duration-200 line-clamp-2 mb-2 leading-snug">{game.title}</h3>
                      {game.description && <p class="text-sm text-zinc-500 line-clamp-3 leading-relaxed flex-1">{game.description}</p>}
                      {date && (
                        <div class="mt-4 pt-3.5 border-t border-zinc-800 flex items-center gap-1.5">
                          <svg class="w-3 h-3 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                          <span class="text-xs text-zinc-600 font-medium">{date}</span>
                        </div>
                      )}
                    </div>
                  </a>
                );
              })}
            </div>
          )}
        </div>
      </div>
    )}
  </div>
</Layout>