---
import Layout from "../layouts/Layout.astro";
import { fetchJSON } from "../lib/api";

let homeRes       = { data: null };
let gamesRes      = { data: [] };
let categoriesRes = { data: [] };
let articlesRes   = { data: [] };

try { homeRes       = await fetchJSON("/api/home-page"); }       catch (e) { console.error(e); }
try { gamesRes      = await fetchJSON("/api/games?populate=category&pagination%5BpageSize%5D=100&sort=release_date:desc"); } catch (e) { console.error(e); }
try { categoriesRes = await fetchJSON("/api/categories?sort=order:asc&pagination%5BpageSize%5D=50"); } catch (e) { console.error(e); }
try { articlesRes   = await fetchJSON("/api/articles?pagination%5BpageSize%5D=4&sort=publishedAt:desc"); } catch (e) { console.error(e); }

const p = homeRes?.data?.attributes ?? homeRes?.data ?? {};

const ui = {
  heroTag: p.heroTag,
  heroTitle: p.heroTitle,
  heroTitleAccent: p.heroTitleAccent,
  heroSubtitle: p.heroSubtitle,
  cta1Label: p.cta1Label,
  cta1Href: p.cta1Href,
  cta2Label: p.cta2Label,
  cta2Href: p.cta2Href,
  cta3Label: p.cta3Label,
  cta3Href: p.cta3Href,
  statGamesLabel: p.statGamesLabel,
  statCategoriesLabel: p.statCategoriesLabel,
  statCustomValue: p.statCustomValue,
  statCustomLabel: p.statCustomLabel,
  categoriesSectionTitle: p.categoriesSectionTitle,
  categoriesLinkLabel: p.categoriesLinkLabel,
  categoriesLinkHref: p.categoriesLinkHref,
  gamesSectionTitle: p.gamesSectionTitle,
  gamesLinkLabel: p.gamesLinkLabel,
  gamesLinkHref: p.gamesLinkHref,
  articlesSectionTitle: p.articlesSectionTitle,
  articlesLinkLabel: p.articlesLinkLabel,
  articlesLinkHref: p.articlesLinkHref,
  articlesEmptyText: p.articlesEmptyText,
};

function extractText(raw: any): string {
  if (!raw) return "";
  if (typeof raw === "string") return raw;
  if (Array.isArray(raw)) {
    return raw.map((b: any) =>
      Array.isArray(b?.children) ? b.children.map((c: any) => c?.text ?? "").join("") : ""
    ).join(" ").trim();
  }
  return "";
}

const rawGames = gamesRes?.data ?? [];
const games = rawGames.slice(0, 6).map((g: any) => {
  const a = g?.attributes ?? g;
  const catAttrs = a?.category?.data?.attributes ?? a?.category ?? null;
  return {
    title: a.title,
    slug: a.slug ?? String(g.id),
    description: extractText(a.description),
    release_date: a.release_date ?? null,
    category: catAttrs?.name,
    accentColor: catAttrs?.accentColor,
    bgColor: catAttrs?.bgColor,
    borderColor: catAttrs?.borderColor,
  };
});

const rawCategories = categoriesRes?.data ?? [];
const categories = rawCategories.map((c: any) => {
  const a = c?.attributes ?? c;
  return {
    name: a.name,
    slug: a.slug ?? String(c.id),
    icon: a.icon,
    accentColor: a.accentColor,
    bgColor: a.bgColor,
    borderColor: a.borderColor,
  };
});

const rawArticles = articlesRes?.data ?? [];
const articles = rawArticles.map((a: any) => {
  const d = a?.attributes ?? a;
  return {
    title: d.title,
    slug: d.slug ?? String(a.id),
    excerpt: extractText(d.excerpt ?? d.content),
    publishedAt: d.publishedAt ?? null,
  };
});

const totalGames = rawGames.length;
const totalCategories = categories.length;

const DEFAULT_ACCENT = "#a1a1aa";
const DEFAULT_BG = "rgba(113,113,122,0.1)";
const DEFAULT_BORDER = "rgba(113,113,122,0.2)";

function formatDate(dateStr: string | null): string | null {
  if (!dateStr) return null;
  const d = new Date(dateStr);
  if (isNaN(d.getTime())) return null;
  return d.toLocaleDateString("es-ES", { year: "numeric", month: "short", day: "numeric" });
}
---

<Layout title="GameVault | Home">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800;900&display=swap');
    body { font-family: 'Outfit', sans-serif; }
    .line-clamp-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .line-clamp-3 { display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
    .anim-1 { animation: fadeUp 0.5s ease 0.0s both; }
    .anim-2 { animation: fadeUp 0.5s ease 0.1s both; }
    .anim-3 { animation: fadeUp 0.5s ease 0.2s both; }
    .anim-4 { animation: fadeUp 0.5s ease 0.3s both; }
    .cat-track { display: flex; gap: 12px; transition: transform 0.35s cubic-bezier(0.4,0,0.2,1); will-change: transform; }
    .cat-track.no-transition { transition: none; }
    .cat-card { flex: 0 0 calc(25% - 9px); min-width: 0; }
    .cat-item { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 20px; border-radius: 16px; border: 1px solid; transition: transform 0.2s ease, box-shadow 0.2s ease; text-decoration: none; height: 100%; box-sizing: border-box; }
    .cat-item:hover { transform: scale(1.06); box-shadow: 0 12px 32px rgba(0,0,0,0.4); }
    @media (max-width: 1024px) { .cat-card { flex: 0 0 calc(33.333% - 8px); } }
    @media (max-width: 640px)  { .cat-card { flex: 0 0 calc(50% - 6px); } }
  </style>

  <div class="min-h-screen bg-zinc-950 text-zinc-100">

    <section class="relative overflow-hidden border-b border-zinc-800/60">
      <div class="absolute w-[600px] h-[600px] rounded-full pointer-events-none -top-48 left-1/2 -translate-x-1/2" style="background: radial-gradient(circle, rgba(124,58,237,0.15) 0%, transparent 70%)"></div>
      <div class="max-w-6xl mx-auto px-6 py-24 relative z-10">

        {ui.heroTag && (
          <div class="anim-1 inline-flex items-center gap-2 bg-violet-500/10 border border-violet-500/25 text-violet-400 text-xs font-semibold tracking-widest uppercase px-3.5 py-1.5 rounded-full mb-8">
            <span class="w-1.5 h-1.5 rounded-full bg-violet-400 inline-block"></span>
            {ui.heroTag}
          </div>
        )}

        <h1 class="anim-2 text-6xl sm:text-7xl font-black tracking-tight leading-[1.05] mb-6 max-w-3xl">
          {ui.heroTitle && <span class="text-white">{ui.heroTitle} </span>}
          {ui.heroTitleAccent && <span class="text-violet-400">{ui.heroTitleAccent}</span>}
        </h1>

        {ui.heroSubtitle && (
          <p class="anim-3 text-zinc-400 text-xl leading-relaxed max-w-2xl mb-10">{ui.heroSubtitle}</p>
        )}

        <div class="anim-4 flex flex-wrap gap-3 mb-16">
          {ui.cta1Label && (
            <a href={ui.cta1Href} class="inline-flex items-center gap-2 bg-violet-600 hover:bg-violet-500 text-white font-semibold px-6 py-3 rounded-xl transition-all hover:-translate-y-0.5 hover:shadow-lg hover:shadow-violet-500/25 text-sm">
              {ui.cta1Label}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          )}
          {ui.cta2Label && (
            <a href={ui.cta2Href} class="inline-flex items-center gap-2 bg-zinc-900 hover:bg-zinc-800 text-zinc-300 font-semibold px-6 py-3 rounded-xl border border-zinc-800 hover:border-zinc-700 transition-all text-sm">
              {ui.cta2Label}
            </a>
          )}
          {ui.cta3Label && (
            <a href={ui.cta3Href} class="inline-flex items-center gap-2 bg-zinc-900 hover:bg-zinc-800 text-zinc-300 font-semibold px-6 py-3 rounded-xl border border-zinc-800 hover:border-zinc-700 transition-all text-sm">
              {ui.cta3Label}
            </a>
          )}
        </div>

        <div class="flex flex-wrap gap-10">
          <div>
            <p class="text-4xl font-black text-white">{totalGames}</p>
            <p class="text-sm text-zinc-500 mt-1">{ui.statGamesLabel}</p>
          </div>
          <div class="w-px bg-zinc-800 self-stretch"></div>
          <div>
            <p class="text-4xl font-black text-white">{totalCategories}</p>
            <p class="text-sm text-zinc-500 mt-1">{ui.statCategoriesLabel}</p>
          </div>
          <div class="w-px bg-zinc-800 self-stretch"></div>
          <div>
            <p class="text-4xl font-black text-violet-400">{ui.statCustomValue}</p>
            <p class="text-sm text-zinc-500 mt-1">{ui.statCustomLabel}</p>
          </div>
        </div>
      </div>
    </section>

    {categories.length > 0 && (
      <section class="max-w-6xl mx-auto px-6 py-20">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-white tracking-tight">{ui.categoriesSectionTitle}</h2>
          <a href={ui.categoriesLinkHref} class="text-sm font-semibold text-violet-400 hover:text-violet-300 transition-colors">{ui.categoriesLinkLabel}</a>
        </div>

        <div class="flex items-center gap-3">
          <button id="cat-prev" class="w-10 h-10 rounded-full bg-zinc-900 border border-zinc-800 text-zinc-400 hover:bg-zinc-800 hover:text-white hover:border-violet-500/50 flex items-center justify-center transition-all flex-shrink-0" aria-label="Anterior">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
          </button>

          <div class="flex-1 overflow-hidden">
            <div class="py-2 px-1 overflow-hidden">
              <div class="cat-track" id="cat-track">
                {categories.map((cat) => (
                  <div class="cat-card">
                    <a
                      href={"/categories/" + cat.slug}
                      class="cat-item"
                      style={"background:" + (cat.bgColor ?? DEFAULT_BG) + "; border-color:" + (cat.borderColor ?? DEFAULT_BORDER)}
                    >
                      <span class="text-3xl mb-3">{cat.icon}</span>
                      <span class="text-sm font-semibold" style={"color:" + (cat.accentColor ?? DEFAULT_ACCENT)}>{cat.name}</span>
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </div>

          <button id="cat-next" class="w-10 h-10 rounded-full bg-zinc-900 border border-zinc-800 text-zinc-400 hover:bg-zinc-800 hover:text-white hover:border-violet-500/50 flex items-center justify-center transition-all flex-shrink-0" aria-label="Siguiente">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </section>
    )}

    {games.length > 0 && (
      <section class="max-w-6xl mx-auto px-6 pb-16">
        <div class="border-t border-zinc-800/60 pt-16">
          <div class="flex items-center justify-between mb-8">
            <h2 class="text-2xl font-bold text-white tracking-tight">{ui.gamesSectionTitle}</h2>
            <a href={ui.gamesLinkHref} class="text-sm font-semibold text-violet-400 hover:text-violet-300 transition-colors">{ui.gamesLinkLabel}</a>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
            {games.map((game) => {
              const accent = game.accentColor ?? DEFAULT_ACCENT;
              const bg = game.bgColor ?? DEFAULT_BG;
              const border = game.borderColor ?? DEFAULT_BORDER;
              const date = formatDate(game.release_date);
              return (
                <a href={"/games/" + game.slug} class="group flex flex-col bg-zinc-900 border border-zinc-800/80 rounded-2xl overflow-hidden hover:-translate-y-1 hover:shadow-2xl transition-all duration-200">
                  <div class="h-0.5 w-full opacity-0 group-hover:opacity-100 transition-opacity duration-200" style={"background:" + accent}></div>
                  <div class="flex flex-col flex-1 p-5">
                    {game.category && (
                      <span class="self-start text-xs font-semibold px-2.5 py-1 rounded-full border mb-3 tracking-wide" style={"color:" + accent + "; background:" + bg + "; border-color:" + border}>
                        {game.category}
                      </span>
                    )}
                    <h3 class="text-base font-bold text-zinc-100 group-hover:text-violet-400 transition-colors duration-200 line-clamp-2 mb-2 leading-snug">{game.title}</h3>
                    {game.description
                      ? <p class="text-sm text-zinc-500 line-clamp-3 leading-relaxed flex-1">{game.description}</p>
                      : <div class="flex-1"></div>
                    }
                    {date && (
                      <div class="mt-4 pt-3.5 border-t border-zinc-800 flex items-center gap-1.5">
                        <svg class="w-3 h-3 text-zinc-600 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        <span class="text-xs text-zinc-600 font-medium">{date}</span>
                      </div>
                    )}
                  </div>
                </a>
              );
            })}
          </div>

          <div class="mt-10 text-center">
            <a href={ui.gamesLinkHref} class="inline-flex items-center gap-2 bg-zinc-900 hover:bg-zinc-800 text-zinc-300 font-semibold px-8 py-3.5 rounded-xl border border-zinc-800 hover:border-zinc-700 transition-all text-sm">
              {ui.gamesLinkLabel}
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
            </a>
          </div>
        </div>
      </section>
    )}

    <section class="max-w-6xl mx-auto px-6 pb-24">
      <div class="border-t border-zinc-800/60 pt-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-white tracking-tight">{ui.articlesSectionTitle}</h2>
          <a href={ui.articlesLinkHref} class="text-sm font-semibold text-violet-400 hover:text-violet-300 transition-colors">{ui.articlesLinkLabel}</a>
        </div>

        {articles.length === 0 ? (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
            {[1,2,3,4].map(() => (
              <div class="flex flex-col bg-zinc-900/50 border border-zinc-800/50 border-dashed rounded-2xl p-5 min-h-36 items-center justify-center">
                <p class="text-zinc-600 text-sm">{ui.articlesEmptyText}</p>
              </div>
            ))}
          </div>
        ) : (
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
            {articles.map((article) => (
              <a href={"/articles/" + article.slug} class="group flex flex-col bg-zinc-900 border border-zinc-800/80 rounded-2xl overflow-hidden hover:-translate-y-1 hover:shadow-2xl transition-all duration-200">
                <div class="h-0.5 w-full bg-violet-500 opacity-0 group-hover:opacity-100 transition-opacity duration-200"></div>
                <div class="flex flex-col flex-1 p-5">
                  <h3 class="text-sm font-bold text-zinc-100 group-hover:text-violet-400 transition-colors line-clamp-2 mb-2 leading-snug">{article.title}</h3>
                  {article.excerpt && <p class="text-xs text-zinc-500 line-clamp-3 leading-relaxed flex-1">{article.excerpt}</p>}
                  {formatDate(article.publishedAt) && <p class="text-xs text-zinc-600 mt-3 font-medium">{formatDate(article.publishedAt)}</p>}
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

  </div>
</Layout>

<script>
  const track   = document.getElementById("cat-track") as HTMLElement;
  const prevBtn = document.getElementById("cat-prev") as HTMLButtonElement;
  const nextBtn = document.getElementById("cat-next") as HTMLButtonElement;

  if (track && prevBtn && nextBtn) {
    const viewport = track.parentElement as HTMLElement;
    const origCards = Array.from(track.querySelectorAll(".cat-card")) as HTMLElement[];
    const total = origCards.length;

    origCards.forEach(card => {
      const clone = card.cloneNode(true) as HTMLElement;
      clone.setAttribute("aria-hidden", "true");
      track.appendChild(clone);
    });
    origCards.forEach(card => {
      const clone = card.cloneNode(true) as HTMLElement;
      clone.setAttribute("aria-hidden", "true");
      track.insertBefore(clone, track.firstChild);
    });

    const getVisible = () => window.innerWidth >= 1024 ? 4 : window.innerWidth >= 640 ? 3 : 2;
    const getCardWidth = () => (viewport.offsetWidth + 12) / getVisible();

    let current = total;

    function setPos(animated: boolean) {
      if (!animated) track.classList.add("no-transition");
      track.style.transform = "translateX(-" + (current * getCardWidth()) + "px)";
      if (!animated) { track.offsetHeight; track.classList.remove("no-transition"); }
    }

    track.addEventListener("transitionend", () => {
      if (current >= total * 2) { current = total; setPos(false); }
      if (current <= 0) { current = total; setPos(false); }
    });

    prevBtn.addEventListener("click", () => { current--; setPos(true); });
    nextBtn.addEventListener("click", () => { current++; setPos(true); });
    window.addEventListener("resize", () => setPos(false));
    setPos(false);
  }
</script>