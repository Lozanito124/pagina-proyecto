{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "order": {
      "type": "biginteger",
      "required": true
    },
    "Seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false,
      "required": false
    },
    "games": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::game.game",
      "mappedBy": "category"
    },
    "icon": {
      "type": "string"
    },
    "accentColor": {
      "type": "string"
    },
    "bgColor": {
      "type": "string"
    },
    "borderColor": {
      "type": "string"
    }
  }
}
